layout {
    pane split_direction="horizontal" {
        pane split_direction="vertical" {
            pane command="bash" cwd="/home/wyr/workspace" {
                args "-c" "source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh && agent_env_disable_proxy && hermes -p coordinator --continue chat"
            }
            pane command="bash" cwd="/home/wyr/workspace" {
                args "-c" "source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh && agent_env_disable_proxy && hermes -p planner --continue chat"
            }
        }
        pane split_direction="vertical" {
            pane command="bash" cwd="/home/wyr/workspace" {
                args "-c" "source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh && agent_env_disable_proxy && hermes -p implementer --continue chat"
            }
            pane command="bash" cwd="/home/wyr/workspace" {
                args "-c" "source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh && agent_env_disable_proxy && hermes -p critic --continue chat"
            }
        }
    }
}
