#!/usr/bin/env bash
# Compatibility wrapper for the Egomotion4D Kanban launcher.
# `listen-kanban --reset ...` reclaims the current pane; otherwise delegate to
# the 4-pane launcher, which now defaults to visible self-poll delivery.
set -euo pipefail

source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh
agent_env_disable_proxy

if [[ "${1:-}" == "--reset" || "${1:-}" == "reset" || "${1:-}" == "--reset-kanban" ]]; then
    shift
    exec reset-kanban "$@"
fi

exec start-kanban.sh "$@"
