#!/bin/bash
# hermes-kanban-continue — Start hermes with --continue + kanban watcher
#
# Architecture:
#   1. Start hermes_kanban_interactive.py --watch-child as background watcher
#      (claims ready tasks, injects prompts into the pane via zellij)
#   2. Start hermes --continue in foreground (the actual agent session)
#   3. On hermes exit, terminate the watcher
#
# This is the same pattern as codex/codewhale/claude listeners:
# the watcher is a separate process that continuously polls the kanban DB,
# claims tasks, and injects prompts — no /listen-kanban needed.
#
# Environment:
#   HERMES_KANBAN_BOARD        — board slug
#   HERMES_KANBAN_CLAIM_ASSIGNEES — assignees this pane may claim
#   ZELLIJ_SESSION_NAME        — auto set by zellij
#   ZELLIJ_PANE_ID             — auto set; used for injection
#   HERMES_KANBAN_POLL_INTERVAL — poll interval override (seconds)
#   HERMES_KANBAN_WATCHER_SCRIPT — explicit local watcher entry point; defaults
#                                  to the upstream Hermes interactive watcher.
#   HERMES_KANBAN_TOOLSETS      — Hermes CLI toolsets for the pane; default is
#                                  file,terminal,skills,todo,memory,search,web,browser,cronjob,delegation,session_search,vision,clarify,code_execution.
#                                  Set to empty/all or pass -t/--toolsets to
#                                  opt out/override. Toolsets are fixed at
#                                  session start; Hermes cannot hot-load a
#                                  missing tool schema mid-session.

set -euo pipefail

HERMES_ARGS=()
for arg in "$@"; do
    HERMES_ARGS+=("$arg")
done

has_toolsets_arg=0
for ((i=0; i<${#HERMES_ARGS[@]}; i++)); do
    case "${HERMES_ARGS[$i]}" in
        -t|--toolsets|--toolsets=*)
            has_toolsets_arg=1
            break
            ;;
    esac
done
KANBAN_TOOLSETS="${HERMES_KANBAN_TOOLSETS:-file,terminal,skills,todo,memory,search,web,browser,cronjob,delegation,session_search,vision,clarify,code_execution}"
if [ "$has_toolsets_arg" = "0" ] && [ -n "$KANBAN_TOOLSETS" ] && [ "$KANBAN_TOOLSETS" != "all" ]; then
    HERMES_ARGS+=("-t" "$KANBAN_TOOLSETS")
fi

# Extract profile from args (e.g. -p implementer)
PROFILE=""
for ((i=0; i<${#HERMES_ARGS[@]}; i++)); do
    if [ "${HERMES_ARGS[$i]}" = "-p" ] && [ $((i+1)) -lt ${#HERMES_ARGS[@]} ]; then
        PROFILE="${HERMES_ARGS[$((i+1))]}"
        break
    fi
done

# Detect zellij context
SESSION="${ZELLIJ_SESSION_NAME:-}"
PANE_ID="${ZELLIJ_PANE_ID:-}"
BOARD="${HERMES_KANBAN_BOARD:-}"
CLAIM_ASSIGNEES="${HERMES_KANBAN_CLAIM_ASSIGNEES:-}"
WORKSPACE="$(pwd)"

log_prefix="[hermes-kanban-continue]"

if [ -z "$SESSION" ] || [ -z "$PANE_ID" ]; then
    # Not inside zellij — just run hermes normally
    echo "$log_prefix No zellij context, starting hermes without watcher" >&2
    exec hermes "${HERMES_ARGS[@]}"
fi

# Resolve the watcher script. start-kanban.sh selects the task-scoped local
# role-context overlay; direct/manual wrapper use keeps the upstream default.
WATCHER_SCRIPT="${HERMES_KANBAN_WATCHER_SCRIPT:-/home/wyr/.hermes/hermes-agent/plugins/kanban/hermes_listener/hermes_kanban_interactive.py}"
if [ ! -f "$WATCHER_SCRIPT" ]; then
    echo "$log_prefix WARNING: watcher script not found at $WATCHER_SCRIPT, falling back to hermes without watcher" >&2
    exec hermes "${HERMES_ARGS[@]}"
fi

# Build watcher command
WATCHER_CMD=(
    /home/wyr/miniconda/bin/conda run -n egomotion4d python3 "$WATCHER_SCRIPT"
    --watch-child
    --profile "${PROFILE:-implementer}"
    --board "${BOARD:-egomotion4d}"
    --workspace "$WORKSPACE"
    --zellij-session "$SESSION"
    --zellij-pane-id "$PANE_ID"
    --startup-delay-s 5.0
    --auto-start
)
if [ -n "$CLAIM_ASSIGNEES" ]; then
    WATCHER_CMD+=(--claim-assignees "$CLAIM_ASSIGNEES")
fi

# Log file for watcher output
LOG_DIR="/home/wyr/.hermes/hermes-agent/plugins/kanban/logs"
mkdir -p "$LOG_DIR"
WATCHER_LOG="$LOG_DIR/hermes-watcher-${PROFILE:-implementer}.log"

echo "$log_prefix Starting watcher: ${WATCHER_CMD[*]}" >&2
echo "$log_prefix Watcher log: $WATCHER_LOG" >&2

# Start watcher in background (separate session so it survives hermes exit briefly)
watcher_pid=""
(
    exec "${WATCHER_CMD[@]}"
) >> "$WATCHER_LOG" 2>&1 &
watcher_pid=$!

echo "$log_prefix Watcher started: pid=$watcher_pid profile=${PROFILE:-implementer} board=${BOARD:-egomotion4d} pane=$SESSION:$PANE_ID" >&2

# Start hermes in foreground (it takes over this process)
cleanup() {
    echo "$log_prefix Hermes exited, stopping watcher pid=$watcher_pid" >&2
    kill "$watcher_pid" 2>/dev/null || true
    wait "$watcher_pid" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Auto-detect: add --continue only if the profile has a session to resume
CONTINUE_ARG=""
SESSION_DB="/home/wyr/.hermes/profiles/${PROFILE:-implementer}/state.db"
if [ -f "$SESSION_DB" ]; then
    HAS_SESSION=$(python3 -c "
import sqlite3
try:
    c = sqlite3.connect('$SESSION_DB')
    cur = c.execute('SELECT COUNT(*) FROM sessions')
    n = cur.fetchone()[0]
    c.close()
    print(int(n > 0))
except:
    print(0)
" 2>/dev/null || echo 0)
    if [ "$HAS_SESSION" = "1" ]; then
        CONTINUE_ARG="--continue"
        echo "$log_prefix Session DB found with entries, will resume" >&2
    else
        echo "$log_prefix Session DB found but empty, starting new session" >&2
    fi
else
    echo "$log_prefix No session DB for profile ${PROFILE:-implementer}, starting new session" >&2
fi

echo "$log_prefix Starting hermes ${HERMES_ARGS[*]} $CONTINUE_ARG" >&2
exec hermes "${HERMES_ARGS[@]}" $CONTINUE_ARG
