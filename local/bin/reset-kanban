#!/usr/bin/env bash
# Reclaim the current visible Kanban pane's running task claim.
# Defaults are inferred from the pane environment used by start-kanban.sh.
set -euo pipefail

source /home/wyr/.hermes/hermes-agent/local/bin/agent-env.sh
agent_env_disable_proxy

agent="${KANBAN_RESET_AGENT:-}"
args=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --agent)
            if [[ $# -lt 2 ]]; then
                echo "reset-kanban: --agent requires codex or codewhale" >&2
                exit 2
            fi
            agent="${2,,}"
            shift 2
            ;;
        --agent=*)
            agent="${1#--agent=}"
            agent="${agent,,}"
            shift
            ;;
        --codex)
            agent="codex"
            shift
            ;;
        --codewhale)
            agent="codewhale"
            shift
            ;;
        --reset|--reset-kanban)
            # Accepted for compatibility with listen-kanban --reset.
            shift
            ;;
        *)
            args+=("$1")
            shift
            ;;
    esac
done

arg_value() {
    local key="$1"
    local i
    for ((i = 0; i < ${#args[@]}; i++)); do
        if [[ "${args[$i]}" == "$key" && $((i + 1)) -lt ${#args[@]} ]]; then
            printf '%s' "${args[$((i + 1))]}"
            return 0
        fi
        if [[ "${args[$i]}" == "$key="* ]]; then
            printf '%s' "${args[$i]#"$key="}"
            return 0
        fi
    done
    return 1
}

profile="$(arg_value --profile || true)"
profile="${profile:-${HERMES_PROFILE:-${HERMES_KANBAN_PROFILE:-}}}"

if [[ -z "$agent" ]]; then
    if [[ -n "${CODEX_KANBAN_WORKSPACE:-}" ]]; then
        agent="codex"
    elif [[ -n "${CODEWHALE_KANBAN_WORKSPACE:-}" ]]; then
        agent="codewhale"
    else
        case "$profile" in
            planner|coordinator)
                agent="codex"
                ;;
            *)
                agent="codewhale"
                ;;
        esac
    fi
fi

case "$agent" in
    codex|codex-tui|codex-interactive)
        exec codex-kanban-interactive "${args[@]}" --reset-kanban
        ;;
    codewhale|codewhale-tui|deepseek|deepseek-tui|deepseek-interactive)
        exec codewhale-kanban-interactive "${args[@]}" --reset-kanban
        ;;
    *)
        echo "reset-kanban: unknown --agent '$agent' (expected codex or codewhale)" >&2
        exit 2
        ;;
esac
